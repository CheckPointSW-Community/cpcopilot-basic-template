# Check Point CoPilot Codespaces template example values (non-secret)
CHECKPOINT_MGMT_HOST=
CHECKPOINT_MGMT_URL=
CHECKPOINT_API_KEY=
CHECKPOINT_USERNAME=admin
CHECKPOINT_PASSWORD=demo123
CHECKPOINT_MGMT_PORT=443
CHECKPOINT_DOC_CLIENT_ID=
CHECKPOINT_DOC_SECRET_KEY=
CHECKPOINT_DOC_REGION=EU
CHECKPOINT_DOC_AUTH_URL=
OPENCODE_SERVER_USERNAME=opencode
OPENCODE_SERVER_PASSWORD=
OPENCODE_PORT=4096
REPORTS_PORT=8081

# Use CHECKPOINT_MGMT_HOST for on-premises management, or CHECKPOINT_MGMT_URL for Smart-1 Cloud.
# Smart-1 Cloud requires CHECKPOINT_API_KEY and does not use CHECKPOINT_MGMT_PORT or username/password.
# Optional defaults shown above use the same env names as guided setup.
